# The ONLY OpenRouter env var — the key is pre-configured with its model on the
# OpenRouter side, so requests never specify a model.
OPENROUTER_API_KEY=sk-or-...

# Local embedding model (transformers.js / ONNX), downloaded once on first use.
# Default: public, 384-dim, ~34MB quantized. Set EMBEDDING_DIMENSION to match
# if you change the model (e.g. jina code models are 768-dim but HF-gated).
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# Where the vector index and model cache live.
RAG_DATA_DIR=.rag-data

# Retrieval defaults
TOP_K_DEFAULT=5
EVAL_K_DEFAULT=5
